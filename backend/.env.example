DATABASE_URL=postgres://postgres:pgAdmin4@localhost:5433/dal_syllabus?sslmode=disable
PORT=8090
FRONTEND_URL=http://localhost:4321
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
JWT_SECRET=

# Local dev only: point at a fake-gcs-server container instead of real GCS.
# See README/chat history for how to spin up the emulator + generate a throwaway signing key.
GCS_API_ENDPOINT=http://localhost:4443
GCS_PROJECT_ID=dal-syllabus-dev
GCS_BUCKET_NAME=dal-syllabus-pdfs
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# Comma-separated allowlist of admin emails (must be @dal.ca, since only
# @dal.ca addresses can complete the OTP flow at all).
ADMIN_EMAILS=
